    "@commitlint/config-conventional": "17.0.3",
    "@layer0/cli": "4.17.0",
    "@layer0/core": "4.17.0",
    "@layer0/devtools": "4.17.0",
    "@layer0/next": "4.17.0",
    "@layer0/prefetch": "4.17.0",
